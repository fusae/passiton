# ── Data directory ─────────────────────────────────────────────────────────────
# Override the default data directory (~/.passiton). The directory holds config.json,
# turing.db, and all persistent state. Useful for tests, multi-instance, or custom layouts.
# Legacy TURING_* environment variables are still accepted as fallbacks.
# PASSITON_HOME=/data/passiton

# ── Server ────────────────────────────────────────────────────────────────────
# Override the HTTP listen port. Priority: PORT > config file server.port > default 4590.
PORT=4590
PASSITON_HOST=127.0.0.1
NODE_ENV=production

# ── Auth / Crypto (auto-generated on first run if unset) ───────────────────────
# Strongly recommended to set these explicitly for Server Mode.
PASSITON_JWT_SECRET=
PASSITON_ENCRYPTION_KEY=

# ── Auth behavior ──────────────────────────────────────────────────────────────
# Local-access auto-login. Disable when exposing beyond localhost.
PASSITON_LOCAL_ACCESS=true
# Allow new user registration. Leave disabled for single-user local use.
PASSITON_ALLOW_REGISTRATION=false

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated browser origins allowed beyond localhost/127.0.0.1/::1.
# PASSITON_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# ── Agent discovery ────────────────────────────────────────────────────────────
# Probe the host for installed CLI agents (codex, claude, gemini, opencode).
# Enable for local-first use; disable for cloud deployments.
PASSITON_LOCAL_CLI_AGENTS=true

# Override CLI agent binary locations (auto-detected from PATH if unset).
# PASSITON_CODEX_COMMAND=/usr/local/bin/codex
# PASSITON_CLAUDE_COMMAND=/usr/local/bin/claude
# PASSITON_GEMINI_COMMAND=/usr/local/bin/gemini
# PASSITON_OPENCODE_COMMAND=/usr/local/bin/opencode

# ── Policy ─────────────────────────────────────────────────────────────────────
# Colon-separated list of directories CLI agents may operate in.
# Empty defaults to the process working directory; set explicit roots for real use.
# PASSITON_ALLOWED_WORKSPACES=/Users/you/Projects:/Users/you/Documents

# ── External-task providers (bundled examples, disabled unless configured) ─────
# Dreamina video generation pipeline (bundled example provider, see
# src/examples/dreamina/). Required only if you use video_generate workflow
# steps. If unset, the provider is inert and the engine core is vendor-free.
# PASSITON_DREAMINA_COMMAND=/path/to/dreamina
# Gemini Image storyboard generation. Requires a Gemini Web session.
# PASSITON_GEMINI_SKILL_SCRIPT=/path/to/gemini-web-skill/main.ts
# GEMINI_WEB_COOKIE_PATH=/path/to/cookies.json
# Override ffmpeg/curl/npx used by media adapters (rarely needed).
# PASSITON_FFMPEG_COMMAND=ffmpeg
# PASSITON_CURL_COMMAND=curl
# PASSITON_NPX_COMMAND=npx
