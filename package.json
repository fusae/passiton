{
  "name": "passiton",
  "version": "0.2.2",
  "description": "Passiton agent-to-agent communication proxy",
  "type": "module",
  "main": "electron/main.cjs",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "passiton": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-web.mjs",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run build",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "npm run build && node scripts/run-tests.mjs",
    "app": "npm run build && electron .",
    "app:quick": "electron .",
    "deploy:check": "npm run build && node scripts/deploy-check.mjs",
    "prepublishOnly": "npm run check"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "uuid": "^9.0.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "electron": "^42.4.1",
    "typescript": "^5.3.3"
  },
  "files": [
    "dist",
    "!dist/tests",
    "config",
    "electron"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fusae/passiton.git"
  },
  "homepage": "https://github.com/fusae/passiton#readme",
  "bugs": {
    "url": "https://github.com/fusae/passiton/issues"
  },
  "license": "Apache-2.0",
  "keywords": [
    "agents",
    "multi-agent",
    "orchestration",
    "agent-handoff",
    "local-first",
    "claude-code",
    "codex",
    "gemini-cli",
    "opencode",
    "workflow",
    "mcp"
  ]
}
